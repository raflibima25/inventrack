# ============================================================
# InvenTrack - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ------------------------------------------------------------
# Database (Supabase PostgreSQL - required)
# IMPORTANT: Use port 5432 (Session mode) for VPS / self-hosted deployment
# Use port 6543 (Transaction mode / pgBouncer) only for serverless (Vercel, etc.)
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# Authentication (required)
# Generate AUTH_SECRET with: npx auth secret
# ------------------------------------------------------------
AUTH_SECRET=your-auth-secret-min-32-chars
AUTH_TRUST_HOST=true

# ------------------------------------------------------------
# MinIO Self-Hosted Storage (required for photo & logo upload)
# Setup guide: install MinIO on your VPS, create a bucket, and generate an Access Key.
#
# MINIO_ENDPOINT    : Full URL to your MinIO S3 API (e.g. https://storage.yourdomain.com)
# MINIO_ACCESS_KEY  : Access Key generated from MinIO Console → Access Keys
# MINIO_SECRET_KEY  : Secret Key generated from MinIO Console → Access Keys
# MINIO_BUCKET_NAME : Name of the bucket you created (e.g. inventrack)
# MINIO_PUBLIC_URL  : Public base URL for serving files (usually same as MINIO_ENDPOINT)
# MINIO_HOSTNAME    : Hostname only (no protocol) — used by Next.js remotePatterns
# ------------------------------------------------------------
MINIO_ENDPOINT=https://storage.yourdomain.com
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=inventrack
MINIO_PUBLIC_URL=https://storage.yourdomain.com
MINIO_HOSTNAME=storage.yourdomain.com

# ------------------------------------------------------------
# Google Gemini AI (required for AI image extraction feature)
# Get from: https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# ------------------------------------------------------------
# App Configuration (required)
# NEXT_PUBLIC_APP_URL : Base URL of the app (used for absolute links, QR codes, etc.)
# App name & institution name are managed via Settings in the app dashboard (saved to DB).
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
